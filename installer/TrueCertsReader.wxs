<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="TrueCerts Reader"
    Manufacturer="TheTrueCerts.com"
    Language="1033"
    Version="1.0.2"
    UpgradeCode="{573400F1-6B0E-4BAF-8F9F-DA2783BA73ED}">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      InstallPrivileges="elevated" />

    <!-- Force root drive (exact C:\TheTrueCerts.com\) -->
    <Property Id="ROOTDRIVE" Value="C:\" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <!-- Single-file MSI -->
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- Install directory: C:\TheTrueCerts.com\ -->
      <Directory Id="INSTALLDIR" Name="TheTrueCerts.com" />

      <!-- ✅ Per-user Start Menu (Roaming): %APPDATA%\Microsoft\Windows\Start Menu\Programs -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="TrueCertsMenuDir" Name="TheTrueCerts.com" />
      </Directory>

    </Directory>

    <Feature Id="MainFeature" Title="TrueCerts Reader" Level="1">
      <ComponentGroupRef Id="CG_Main" />
    </Feature>

    <WixVariable Id="WixUILicenseRtf" Value="$(var.RepoDir)\installer\license.rtf" />
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />

  </Product>

  <!-- =========================
       INSTALLDIR components
       ========================= -->
  <Fragment>
    <DirectoryRef Id="INSTALLDIR">

      <!-- Main EXE (per-machine) -->
      <Component Id="cmpReaderExe" Guid="{AD0C6346-0A1B-4C3A-B09F-0AB9D1CF4556}">
        <File Id="filReaderExe" Source="$(var.SourceDir)\ttc-reader.exe" KeyPath="yes" />

        <!-- Optional: Win+R / Search launch by filename -->
        <RegistryKey Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\App Paths\ttc-reader.exe">
          <RegistryValue Type="string" Value="[#filReaderExe]" />
          <RegistryValue Name="Path" Type="string" Value="[INSTALLDIR]" />
        </RegistryKey>

        <!-- .ttc association (per-machine) -->
        <RegistryKey Root="HKCR" Key=".ttc">
          <RegistryValue Type="string" Value="TrueCerts.ttc"/>
        </RegistryKey>

        <RegistryKey Root="HKCR" Key=".ttc\OpenWithProgids">
          <RegistryValue Name="TrueCerts.ttc" Type="string" Value=""/>
        </RegistryKey>

        <RegistryKey Root="HKCR" Key="TrueCerts.ttc">
          <RegistryValue Type="string" Value="TrueCerts Dumps File"/>
        </RegistryKey>

        <RegistryKey Root="HKCR" Key="TrueCerts.ttc\DefaultIcon">
          <RegistryValue Type="string" Value="&quot;[#filReaderExe]&quot;,0"/>
        </RegistryKey>

        <RegistryKey Root="HKCR" Key="TrueCerts.ttc\shell\open\command">
          <RegistryValue Type="string" Value="&quot;[#filReaderExe]&quot; &quot;%1&quot;"/>
        </RegistryKey>

        <RemoveRegistryKey Root="HKCR" Key="TrueCerts.ttc" Action="removeOnUninstall"/>
        <RemoveRegistryKey Root="HKCR" Key=".ttc" Action="removeOnUninstall"/>

      </Component>

      <!-- pdfium.dll -->
      <Component Id="cmpPdfium" Guid="{FFBD12D7-8A26-4486-BE70-0AA060645E3D}">
        <File Id="filPdfium" Source="$(var.SourceDir)\pdfium.dll" KeyPath="yes" />
      </Component>

    </DirectoryRef>
  </Fragment>

  <!-- =========================
       Start Menu shortcut (per-user roaming)
       ========================= -->
  <Fragment>
    <DirectoryRef Id="TrueCertsMenuDir">
      <Component Id="cmpStartMenuShortcut" Guid="{F4D1E7F1-7DA8-4E24-9A88-2E4B4D73A3B7}">
        <Shortcut Id="StartMenuShortcut"
                  Name="TrueCerts Reader"
                  Description="TrueCerts Reader"
                  Target="[#filReaderExe]"
                  WorkingDirectory="INSTALLDIR" />

        <RemoveFolder Id="RemoveTrueCertsMenuDir" Directory="TrueCertsMenuDir" On="uninstall" />

        <!-- ✅ KeyPath MUST be HKCU because this component installs into user profile -->
        <RegistryValue Root="HKCU"
                       Key="Software\TheTrueCerts.com\TrueCerts Reader"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>

  <!-- =========================
       Component group
       ========================= -->
  <Fragment>
    <ComponentGroup Id="CG_Main">
      <ComponentRef Id="cmpReaderExe" />
      <ComponentRef Id="cmpPdfium" />
      <ComponentRef Id="cmpStartMenuShortcut" />
    </ComponentGroup>
  </Fragment>

</Wix>
